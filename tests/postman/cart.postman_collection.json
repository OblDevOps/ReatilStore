{
  "info": {
    "name": "Cart API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "customerId",
      "value": "customer-001"
    },
    {
      "key": "itemId",
      "value": "item-abc"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Service is UP', function () {",
              "  pm.expect(pm.response.json().status).to.equal('UP');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Get cart (empty)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Cart has correct customerId and empty items', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('customerId', pm.collectionVariables.get('customerId'));",
              "  pm.expect(body.items).to.be.an('array').with.lengthOf(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carts/{{customerId}}"
      }
    },
    {
      "name": "Add item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Item has required fields', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('itemId', pm.collectionVariables.get('itemId'));",
              "  pm.expect(body).to.have.property('quantity', 2);",
              "  pm.expect(body).to.have.property('unitPrice', 5000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/carts/{{customerId}}/items",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemId\": \"item-abc\",\n  \"quantity\": 2,\n  \"unitPrice\": 5000\n}"
        }
      }
    },
    {
      "name": "Get items (with data)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Items list contains added item', function () {",
              "  var items = pm.response.json();",
              "  pm.expect(items).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(items[0].itemId).to.equal(pm.collectionVariables.get('itemId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carts/{{customerId}}/items"
      }
    },
    {
      "name": "Get specific item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Item fields are correct', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.itemId).to.equal(pm.collectionVariables.get('itemId'));",
              "  pm.expect(body.quantity).to.equal(2);",
              "  pm.expect(body.unitPrice).to.equal(5000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carts/{{customerId}}/items/{{itemId}}"
      }
    },
    {
      "name": "Update item quantity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 202', function () {",
              "  pm.response.to.have.status(202);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/carts/{{customerId}}/items",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemId\": \"item-abc\",\n  \"quantity\": 5,\n  \"unitPrice\": 5000\n}"
        }
      }
    },
    {
      "name": "Get item after update",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Quantity was updated', function () {",
              "  pm.expect(pm.response.json().quantity).to.equal(5);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carts/{{customerId}}/items/{{itemId}}"
      }
    },
    {
      "name": "Delete item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 202', function () {",
              "  pm.response.to.have.status(202);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/carts/{{customerId}}/items/{{itemId}}"
      }
    },
    {
      "name": "Get items (empty after delete)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Items list is empty', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/carts/{{customerId}}/items"
      }
    },
    {
      "name": "Delete cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 202', function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "pm.test('Response has customerId', function () {",
              "  pm.expect(pm.response.json().customerId).to.equal(pm.collectionVariables.get('customerId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/carts/{{customerId}}"
      }
    }
  ]
}
